<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicesPolicy" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <permission android:name="com.pg_axis.musicaxs.PLAYLIST_ACCESS" android:protectionLevel="normal" />

    <queries>
        <package android:name="com.pg_axis.ytcnv" />
    </queries>

    <application
        android:name=".MusicAxsApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Musicaxs">
        <provider
            android:name=".services.MusicAxsProvider"
            android:authorities="com.pg_axis.musicaxs.provider"
            android:exported="true"
            android:permission="com.pg_axis.musicaxs.PLAYLIST_ACCESS" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Musicaxs">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name=".services.MusicService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true"
            android:permission="android.permission.BIND_MEDIA_BROWSER_SERVICE">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>
    </application>

</manifest>